# =============================================================================
# 农场主的鸡窝 — Git 忽略规则
# 原则：构建产物、缓存、密钥、个人持仓数据一律不进仓库
# =============================================================================

# --- 依赖与构建产物 ---
node_modules/
dist/
dist-ssr/
build/
*.local

# --- 工具链缓存 ---
.vite/
*.tsbuildinfo
.eslintcache
coverage/
.turbo/
.cache/

# --- 日志与包管理器 ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnpm-store/
.yarn/cache
.yarn/unplugged
.yarn/install-state.gz
.pnp.*

# --- 环境变量与密钥 ---
.env
.env.*
!.env.example
*.pem
*.key
credentials*.json
secrets*.json

# --- 编辑器与操作系统 ---
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db
desktop.ini
Desktop.ini
ehthumbs.db

# --- Cursor / AI / 临时文件 ---
.cursor/
.claude/
*.tmp
tmp.txt
*~
*.swp
*.swo

# =============================================================================
# 个人基金数据（切勿提交）
# =============================================================================

# 本地 dev 种子（复制 localFunds.example.ts 后填入）
private/localFunds.ts
private/localFunds.*.ts

# private 目录下的数据文件（示例模板除外）
private/*.json
!private/funds.seed.example.json
private/*.{xlsx,xls,csv}

# 导出/备份目录（保留 .gitkeep 占位）
private/exports/**
!private/exports/.gitkeep

# 应用「设置 → 导出」或手动保存在项目内的备份
农场主的鸡窝-*
神秘代码-*
fund-tracker-*

# 项目根目录误建的 exports 文件夹
/exports/**

# =============================================================================
# 可提交的文件（勿在此添加 ignore）
# private/localFunds.example.ts
# private/funds.seed.example.json
# src/data/emptySeed.ts
# =============================================================================
